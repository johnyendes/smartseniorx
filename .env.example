# ================================================================
# SmartSeniorX — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to GitHub
# ================================================================

# ── Anthropic AI (REQUIRED for AI Advisor to work) ──────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# ── ConvertKit Email (for 7-day email series signup) ─────────────
# Get from: app.convertkit.com → Forms → your form URL → ID in URL
CONVERTKIT_FORM_ID=REPLACE_WITH_YOUR_FORM_ID

# ── Stripe (for membership and product payments) ─────────────────
# Get from: dashboard.stripe.com → Payment Links
STRIPE_MEMBER_9=https://buy.stripe.com/REPLACE_MEMBER
STRIPE_PREMIUM_19=https://buy.stripe.com/REPLACE_PREMIUM
STRIPE_EXPAT_29=https://buy.stripe.com/REPLACE_EXPAT
STRIPE_MEDICARE_49=https://buy.stripe.com/REPLACE_MEDICARE
STRIPE_TOOLKIT_79=https://buy.stripe.com/REPLACE_TOOLKIT
STRIPE_ORGANIZER_29=https://buy.stripe.com/REPLACE_ORGANIZER
STRIPE_ESTATE_19=https://buy.stripe.com/REPLACE_ESTATE_CL
STRIPE_REGISTRY_14=https://buy.stripe.com/REPLACE_REGISTRY
STRIPE_BUNDLE_49=https://buy.stripe.com/REPLACE_BUNDLE

# ── Google Analytics (for traffic tracking) ──────────────────────
# Get from: analytics.google.com → Data Streams → Measurement ID
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Search Console (for SEO verification) ─────────────────
# Get from: search.google.com/search-console → HTML tag method
GOOGLE_SITE_VERIFICATION=REPLACE_WITH_YOUR_TOKEN

# ── Site URL (update after connecting custom domain) ─────────────
NEXT_PUBLIC_SITE_URL=https://www.smartseniorx.com
